{
  "name": "openclaw-ha-plugin",
  "version": "0.1.3",
  "description": "Home Assistant integration for OpenClaw — control devices, schedule actions, and get notified",
  "openclaw": {
    "extensions": ["./src/index.ts"],
    "install": {
      "localPath": "extensions/openclaw-ha-plugin",
      "defaultChoice": "local"
    }
  },
  "dependencies": {
    "js-yaml": "^4.1.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.0.0",
    "@types/ws": "^8.5.13",
    "typescript": "^5.0.0"
  }
}
